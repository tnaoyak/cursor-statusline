{
  "name": "cursor-statusline",
  "version": "0.1.1",
  "description": "Interactive setup tool that generates Cursor statusline.sh",
  "author": "tnaoyak",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tnaoyak/cursor-statusline.git"
  },
  "bugs": {
    "url": "https://github.com/tnaoyak/cursor-statusline/issues"
  },
  "homepage": "https://github.com/tnaoyak/cursor-statusline#readme",
  "type": "module",
  "bin": {
    "cursor-statusline": "dist/cli.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --target node20 --out-dir dist --clean",
    "check": "tsc --noEmit",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "prepack": "npm run check && npm run test && npm run build"
  },
  "keywords": [
    "cursor",
    "statusline",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
